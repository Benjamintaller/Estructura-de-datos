def suma_cuadrados(n):
    if n == 1:
        return 1
    else:
        return n*n + suma_cuadrados(n - 1)


def factorial(n):
    if n == 0 or n == 1:
        return 1
    else:
        return n * factorial(n - 1)


def suma_naturales(n):
    if n == 1:
        return 1
    else:
        return n + suma_naturales(n - 1)
